---
interface Props {
  pm25: number;
}

const { pm25 } = Astro.props;
---

<div class="pm25-hero">
  <!-- 3D Glass Text -->
  <div class="glass-text-container">
    <div class="glass-text" data-value={pm25}>
      <span class="digit">{pm25}</span>
    </div>
    <!-- Reflection layer -->
    <div class="glass-text reflection" aria-hidden="true">
      <span class="digit">{pm25}</span>
    </div>
  </div>
  
  <!-- Labels -->
  <div class="labels">
    <span class="pm25-label">PM2.5</span>
    <span class="pm25-unit">μg/m³</span>
  </div>
</div>

<style>
  .pm25-hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 28vh;
    z-index: 10;
    padding: 1rem 0;
  }

  .glass-text-container {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .glass-text {
    position: relative;
    font-family: var(--font-display);
    font-size: clamp(5rem, 18vw, 12rem);
    font-weight: 800;
    line-height: 0.85;
    letter-spacing: -0.03em;
    
    /* 3D Glass Effect - Multiple layered shadows */
    color: rgba(255, 255, 255, 0.9);
    text-shadow:
      /* Inner depth */
      0 0 0 rgba(255, 255, 255, 0.8),
      /* 3D extrusion layers */
      1px 1px 0 rgba(200, 200, 210, 0.4),
      2px 2px 0 rgba(180, 180, 190, 0.35),
      3px 3px 0 rgba(160, 160, 170, 0.3),
      4px 4px 0 rgba(140, 140, 150, 0.25),
      5px 5px 0 rgba(120, 120, 130, 0.2),
      6px 6px 0 rgba(100, 100, 110, 0.15),
      /* Soft glow */
      0 0 40px rgba(255, 255, 255, 0.3),
      0 0 80px rgba(255, 255, 255, 0.2),
      /* Colored glow from theme */
      0 0 60px rgba(var(--theme-color), 0.4),
      0 0 120px rgba(var(--theme-color), 0.2),
      /* Deep shadow */
      8px 12px 30px rgba(0, 0, 0, 0.4);
    
    /* Glass texture */
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.4) 0%,
      rgba(255, 255, 255, 0.1) 50%,
      rgba(255, 255, 255, 0.05) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    
    /* Smooth rendering */
    will-change: transform;
    transform: translateZ(0);
  }

  /* Reflection effect */
  .glass-text.reflection {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    transform: scaleY(-0.3) translateY(-20%);
    opacity: 0.15;
    filter: blur(2px);
    pointer-events: none;
    text-shadow:
      1px -1px 0 rgba(200, 200, 210, 0.3),
      2px -2px 0 rgba(180, 180, 190, 0.25),
      3px -3px 0 rgba(160, 160, 170, 0.2),
      0 0 20px rgba(255, 255, 255, 0.2);
    background: none;
    -webkit-background-clip: unset;
    background-clip: unset;
    color: rgba(255, 255, 255, 0.6);
  }

  .digit {
    display: inline-block;
    /* Subtle float animation */
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0) rotateX(0deg);
    }
    50% {
      transform: translateY(-8px) rotateX(2deg);
    }
  }

  .labels {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    margin-top: 0.5rem;
  }

  .pm25-label {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 4vw, 2rem);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .pm25-unit {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.05em;
  }

  /* Responsive */
  @media (min-width: 768px) {
    .pm25-hero {
      min-height: 40vh;
      padding: 3rem 0;
    }

    .pm25-label {
      font-size: clamp(1.5rem, 3vw, 2.5rem);
    }

    .pm25-unit {
      font-size: 1rem;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .digit {
      animation: none;
    }
    
    .glass-text {
      text-shadow:
        0 0 40px rgba(255, 255, 255, 0.3),
        0 0 60px rgba(var(--theme-color), 0.4),
        4px 6px 20px rgba(0, 0, 0, 0.4);
    }
  }
</style>