---
interface Props {
  pm25: number;
}

const { pm25 } = Astro.props;
---

<div class="pm25-hero">
  <div class="pm25-glow"></div>
  
  <div class="pm25-content">
    <span class="pm25-label">PM2.5</span>
    <span class="pm25-number">
      {pm25}
    </span>
    <span class="pm25-unit">μg/m³</span>
  </div>
</div>

<style>
  .pm25-hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 30vh;
    z-index: 10;
  }

  .pm25-glow {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      ellipse at center,
      rgba(var(--theme-color), 0.2) 0%,
      rgba(var(--theme-color), 0.1) 30%,
      transparent 60%
    );
    filter: blur(40px);
    border-radius: 50%;
    z-index: -1;
    animation: breathe 4s ease-in-out infinite;
  }

  @keyframes breathe {
    0%, 100% {
      opacity: 0.8;
      transform: translate(-50%, -50%) scale(1);
    }
    50% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1.15);
    }
  }

  .pm25-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .pm25-label {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 0.5rem;
  }

  .pm25-number {
    font-family: var(--font-display);
    font-size: clamp(5rem, 20vw, 12rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 0.85;
    /* Dynamic color from parent theme */
    color: rgb(var(--theme-color));
    text-shadow: 
      0 0 20px rgba(var(--theme-color), 0.6),
      0 0 40px rgba(var(--theme-color), 0.4),
      0 0 80px rgba(var(--theme-color), 0.3),
      0 0 120px rgba(var(--theme-color), 0.2);
    will-change: transform;
  }

  .pm25-unit {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-text-dim);
    text-transform: lowercase;
    margin-top: 0.5rem;
  }

  @media (min-width: 768px) {
    .pm25-hero {
      min-height: 35vh;
    }

    .pm25-label {
      font-size: 1rem;
      margin-bottom: 0.75rem;
    }

    .pm25-number {
      font-size: clamp(6rem, 15vw, 14rem);
    }

    .pm25-unit {
      font-size: 1rem;
      margin-top: 0.75rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pm25-glow {
      animation: none;
    }
  }
</style>
