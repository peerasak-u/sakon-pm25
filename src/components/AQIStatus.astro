---
interface Props {
  usTitle: string;
  usTitleEn: string;
}

const { usTitle, usTitleEn } = Astro.props;

// Determine AQI level for styling
function getAQILevel(title: string, titleEn: string): 'good' | 'moderate' | 'sensitive' | 'unhealthy' | 'very-unhealthy' | 'hazardous' {
  const lower = title.toLowerCase();
  const lowerEn = titleEn.toLowerCase();
  
  // Check English first for more reliable matching
  if (lowerEn.includes('good') || lower.includes('ดี')) return 'good';
  if (lowerEn.includes('moderate') || lower.includes('ปานกลาง')) return 'moderate';
  if (lowerEn.includes('sensitive') || lower.includes('เฝ้าระวัง')) return 'sensitive';
  if (lowerEn.includes('unhealthy for sensitive') || lower.includes('ไม่ดีต่อกลุ่มเสี่ยง')) return 'sensitive';
  if (lowerEn.includes('very unhealthy') || lower.includes('ไม่ดีมาก')) return 'very-unhealthy';
  if (lowerEn.includes('unhealthy') || lower.includes('ไม่ดี')) return 'unhealthy';
  if (lowerEn.includes('hazardous') || lower.includes('อันตราย')) return 'hazardous';
  return 'moderate';
}

const level = getAQILevel(usTitle, usTitleEn);

const levelStyles = {
  good: { hue: '145', icon: '●' },      // Green
  moderate: { hue: '45', icon: '●' },   // Yellow-orange
  sensitive: { hue: '25', icon: '●' },  // Orange
  unhealthy: { hue: '0', icon: '●' },   // Red
  'very-unhealthy': { hue: '270', icon: '●' }, // Purple
  hazardous: { hue: '320', icon: '●' }  // Magenta
};

const style = levelStyles[level];
---

<div class="aqi-badge" style={`--aqi-hue: ${style.hue}`}>
  <span class="aqi-dot" aria-hidden="true">{style.icon}</span>
  <div class="aqi-text">
    <span class="aqi-th">{usTitle}</span>
    <span class="aqi-en">{usTitleEn}</span>
  </div>
</div>

<style>
  .aqi-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.25rem;
    border-radius: 50px;
    
    /* Glass pill style */
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    
    /* Glow using theme color from API */
    box-shadow:
      0 4px 20px rgba(0, 0, 0, 0.2),
      0 0 40px rgba(var(--theme-color, 255, 160, 0), 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
    
    transition: all 0.3s ease;
  }

  .aqi-badge:hover {
    background: rgba(255, 255, 255, 0.15);
    box-shadow:
      0 6px 24px rgba(0, 0, 0, 0.25),
      0 0 50px rgba(var(--theme-color, 255, 160, 0), 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.15);
    transform: scale(1.02);
  }

  .aqi-dot {
    font-size: 0.875rem;
    color: rgb(var(--theme-color, 255, 160, 0));
    text-shadow: 0 0 10px rgba(var(--theme-color, 255, 160, 0), 0.8);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.7;
      transform: scale(1.1);
    }
  }

  .aqi-text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .aqi-th {
    font-family: var(--font-thai);
    font-size: 1rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.95);
    line-height: 1.3;
  }

  .aqi-en {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  /* Responsive */
  @media (min-width: 768px) {
    .aqi-badge {
      padding: 0.875rem 1.5rem;
      gap: 0.875rem;
    }

    .aqi-th {
      font-size: 1.125rem;
    }

    .aqi-en {
      font-size: 0.8125rem;
    }
  }

  /* Safari fix */
  @supports not (backdrop-filter: blur(16px)) {
    .aqi-badge {
      background: rgba(50, 50, 60, 0.9);
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .aqi-dot {
      animation: none;
    }
  }
</style>