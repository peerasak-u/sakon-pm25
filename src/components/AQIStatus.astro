---
interface Props {
  usTitle: string;       // Thai status e.g., "คุณภาพอากาศปานกลาง"
  usTitleEn: string;     // English status e.g., "Moderate"
}

const { usTitle, usTitleEn } = Astro.props;
---

<div class="aqi-status">
  <span class="aqi-status-thai">{usTitle}</span>
  <span class="aqi-status-en">{usTitleEn}</span>
</div>

<style>
  .aqi-status {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem 2rem;
    border-radius: 9999px;
    /* Dynamic background and border from theme */
    background: rgba(var(--theme-color), 0.1);
    border: 1px solid rgba(var(--theme-color), 0.4);
    text-align: center;
    backdrop-filter: blur(10px);
    box-shadow: 
      0 0 40px rgba(var(--theme-color), 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    z-index: 10;
  }

  .aqi-status-thai {
    font-family: var(--font-display);
    font-size: clamp(1rem, 4vw, 1.375rem);
    font-weight: 600;
    /* Dynamic color from theme */
    color: rgb(var(--theme-color));
    line-height: 1.3;
    text-shadow: 0 0 20px rgba(var(--theme-color), 0.5);
  }

  .aqi-status-en {
    font-family: var(--font-display);
    font-size: clamp(0.875rem, 3vw, 1rem);
    font-weight: 400;
    color: var(--color-text-secondary);
    margin-top: 0.25rem;
    line-height: 1.3;
  }

  @media (min-width: 768px) {
    .aqi-status {
      padding: 1.25rem 3rem;
    }

    .aqi-status-thai {
      font-size: 1.625rem;
    }

    .aqi-status-en {
      font-size: 1.125rem;
    }
  }
</style>
