---
interface Props {
  nameEn: string;
}

const { nameEn } = Astro.props;
---

<header class="location-header">
  <h1 class="location-name">{nameEn}</h1>
</header>

<style>
  .location-header {
    text-align: center;
    padding: 0.5rem 0;
  }

  .location-name {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.9);
    letter-spacing: 0.02em;
    line-height: 1.4;
    margin: 0;
  }

  /* Responsive */
  @media (min-width: 768px) {
    .location-name {
      font-size: 1.375rem;
    }
  }
</style>