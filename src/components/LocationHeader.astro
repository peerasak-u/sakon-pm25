---
interface Props {
  nameTh: string;
  nameEn: string;
  provinceTh: string;
  provinceEn: string;
}

const { nameTh, nameEn, provinceTh, provinceEn } = Astro.props;

// Clean up the station name for display
function cleanStationName(name: string, province: string): string {
  return name
    .replace('สวนสมเด็จพระศรีนครินทร์', 'สวนศรีนครินทร์')
    .replace('(สระพังทอง)', '')
    .replace('Sri Nakarin Park', 'Sri Nakarin')
    .replace('(Sraphangthong pond)', '')
    .replace(/,\s*Sakon Nakhon Province/i, '')
    .replace(/,\s*จ\.\s*สกลนคร/i, '')
    .replace(/Province$/i, '')
    .replace(/ Park$/i, '')
    .trim();
}

const displayNameEn = cleanStationName(nameEn, provinceEn);
---

<header class="location-header">
  <h1 class="location-name">
    {displayNameEn}, {provinceEn}
  </h1>
</header>

<style>
  .location-header {
    text-align: center;
    padding: 1.25rem 0 0.5rem;
  }

  .location-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.8);
    letter-spacing: 0.02em;
    line-height: 1.4;
    margin: 0;
    white-space: nowrap;
  }

  /* Responsive */
  @media (min-width: 768px) {
    .location-header {
      padding: 1.5rem 0 0.75rem;
    }

    .location-name {
      font-size: 1.25rem;
    }
  }

  @media (min-width: 1024px) {
    .location-name {
      font-size: 1.375rem;
    }
  }
</style>