---
interface Props {
  nameTh: string;
  nameEn: string;
  provinceTh: string;
  provinceEn: string;
}

const { nameTh, nameEn, provinceTh, provinceEn } = Astro.props;
---

<header class="location-header">
  <h1 class="location-thai">{nameTh}</h1>
  <p class="location-english">{nameEn}</p>
  <span class="province-badge">{provinceTh} / {provinceEn}</span>
</header>

<style>
  .location-header {
    text-align: center;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .location-thai {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 4vw, 1.75rem);
    font-weight: 500;
    color: var(--color-text-primary);
    line-height: 1.3;
    margin: 0;
  }

  .location-english {
    font-family: var(--font-display);
    font-size: clamp(0.8125rem, 2.5vw, 1rem);
    font-weight: 400;
    color: var(--color-text-secondary);
    line-height: 1.4;
    margin: 0.375rem 0 0 0;
  }

  .province-badge {
    display: inline-flex;
    margin-top: 0.75rem;
    padding: 0.375rem 1rem;
    border-radius: 9999px;
    background: rgba(var(--theme-color), 0.1);
    border: 1px solid rgba(var(--theme-color), 0.3);
    color: rgb(var(--theme-color));
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.8125rem;
    letter-spacing: 0.02em;
  }

  @media (min-width: 768px) {
    .location-thai {
      font-size: 2rem;
    }

    .location-english {
      font-size: 1.125rem;
    }

    .province-badge {
      font-size: 0.875rem;
      padding: 0.5rem 1.25rem;
      margin-top: 1rem;
    }
  }
</style>
