---
interface Props {
  pm25: number;
  usColor: string;
}

const { pm25, usColor } = Astro.props;

// Parse RGB values
const [r, g, b] = usColor.split(',').map(Number);

// Generate secondary colors based on AQI level
function getSecondaryColors(r: number, g: number, b: number, pm25: number): string {
  // For orange/yellow tones (unhealthy), add complementary cool tones
  if (pm25 > 55) {
    return '80, 90, 110'; // Blue-gray for contrast
  }
  // For green tones (good), add subtle warm accent
  if (pm25 <= 35) {
    return '200, 180, 160'; // Warm beige
  }
  // For yellow/orange tones, add red accent
  return '220, 100, 80'; // Coral red
}

const secondaryColor = getSecondaryColors(r, g, b, pm25);
---

<canvas 
  id="liquid-canvas" 
  class="liquid-background"
  data-primary={usColor}
  data-secondary={secondaryColor}
  data-pm25={pm25}
  aria-hidden="true"
></canvas>

<div class="vignette-overlay"></div>

<style>
  .liquid-background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  .vignette-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
    background: radial-gradient(
      ellipse 80% 80% at 50% 50%,
      transparent 0%,
      transparent 50%,
      rgba(20, 20, 25, 0.4) 100%
    );
  }
</style>

<script>
  interface Uniforms {
    uTime: WebGLUniformLocation | null;
    uResolution: WebGLUniformLocation | null;
    uPrimaryColor: WebGLUniformLocation | null;
    uSecondaryColor: WebGLUniformLocation | null;
    uSpeed: WebGLUniformLocation | null;
  }

  class LiquidBackground {
    private canvas: HTMLCanvasElement;
    private gl: WebGLRenderingContext | null = null;
    private program: WebGLProgram | null = null;
    private uniforms: Uniforms = {
      uTime: null,
      uResolution: null,
      uPrimaryColor: null,
      uSecondaryColor: null,
      uSpeed: null
    };
    private animationId: number = 0;
    private startTime: number = Date.now();
    private primaryColor: number[];
    private secondaryColor: number[];
    private speed: number;

    // Vertex shader - simple fullscreen quad
    private vertexShaderSource = `
      attribute vec2 aPosition;
      void main() {
        gl_Position = vec4(aPosition, 0.0, 1.0);
      }
    `;

    // Fragment shader - liquid gradient mesh
    private fragmentShaderSource = `
      precision mediump float;
      
      uniform float uTime;
      uniform vec2 uResolution;
      uniform vec3 uPrimaryColor;
      uniform vec3 uSecondaryColor;
      uniform float uSpeed;
      
      // Simplex noise functions
      vec3 mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
      vec2 mod289(vec2 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
      vec3 permute(vec3 x) { return mod289(((x*34.0)+1.0)*x); }
      
      float snoise(vec2 v) {
        const vec4 C = vec4(0.211324865405187, 0.366025403784439,
                            -0.577350269189626, 0.024390243902439);
        vec2 i  = floor(v + dot(v, C.yy));
        vec2 x0 = v - i + dot(i, C.xx);
        vec2 i1;
        i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
        vec4 x12 = x0.xyxy + C.xxzz;
        x12.xy -= i1;
        i = mod289(i);
        vec3 p = permute(permute(i.y + vec3(0.0, i1.y, 1.0))
                        + i.x + vec3(0.0, i1.x, 1.0));
        vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy),
                                dot(x12.zw,x12.zw)), 0.0);
        m = m*m;
        m = m*m;
        vec3 x = 2.0 * fract(p * C.www) - 1.0;
        vec3 h = abs(x) - 0.5;
        vec3 ox = floor(x + 0.5);
        vec3 a0 = x - ox;
        m *= 1.79284291400159 - 0.85373472095314 * (a0*a0 + h*h);
        vec3 g;
        g.x = a0.x * x0.x + h.x * x0.y;
        g.yz = a0.yz * x12.xz + h.yz * x12.yw;
        return 130.0 * dot(m, g);
      }
      
      // FBM (Fractal Brownian Motion)
      float fbm(vec2 p) {
        float value = 0.0;
        float amplitude = 0.5;
        float frequency = 1.0;
        for (int i = 0; i < 6; i++) {
          value += amplitude * snoise(p * frequency);
          amplitude *= 0.5;
          frequency *= 2.0;
        }
        return value;
      }
      
      void main() {
        vec2 uv = gl_FragCoord.xy / uResolution;
        vec2 aspect = vec2(uResolution.x / uResolution.y, 1.0);
        
        // Create flowing organic shapes
        float time = uTime * uSpeed * 0.1;
        
        // Multiple layers of noise for liquid effect
        vec2 q = vec2(0.0);
        q.x = fbm(uv * 2.0 + time * 0.3);
        q.y = fbm(uv * 2.0 + vec2(1.0));
        
        vec2 r = vec2(0.0);
        r.x = fbm(uv * 2.0 + q + vec2(1.7, 9.2) + time * 0.15);
        r.y = fbm(uv * 2.0 + q + vec2(8.3, 2.8) + time * 0.126);
        
        float f = fbm(uv * 2.0 + r);
        
        // Create blobby shapes
        float blob1 = smoothstep(0.0, 1.0, f);
        float blob2 = smoothstep(0.2, 0.8, fbm(uv * 1.5 + time * 0.2));
        
        // Mix colors based on noise
        vec3 color = mix(uPrimaryColor / 255.0, uSecondaryColor / 255.0, clamp(blob1 + blob2, 0.0, 1.0));
        
        // Add gradient variation
        color = mix(color, uPrimaryColor / 255.0 * 1.2, smoothstep(0.3, 0.7, uv.y));
        
        // Add subtle brightness variation
        color *= 0.8 + 0.4 * f;
        
        // Darken overall for glassmorphism contrast
        color = mix(color, vec3(0.1, 0.1, 0.12), 0.3);
        
        // Add subtle fog/glow
        float vignette = 1.0 - smoothstep(0.3, 1.2, length((uv - 0.5) * 1.5));
        color *= 0.7 + 0.3 * vignette;
        
        gl_FragColor = vec4(color, 1.0);
      }
    `;

    constructor(canvas: HTMLCanvasElement) {
      this.canvas = canvas;
      
      // Parse colors from data attributes
      const primaryAttr = canvas.dataset.primary || '255,160,0';
      const secondaryAttr = canvas.dataset.secondary || '80,90,110';
      const pm25 = parseFloat(canvas.dataset.pm25 || '50');
      
      this.primaryColor = primaryAttr.split(',').map(Number);
      this.secondaryColor = secondaryAttr.split(',').map(Number);
      
      // Speed based on PM2.5 (higher = faster/more chaotic)
      this.speed = pm25 <= 12 ? 0.3 : pm25 <= 35 ? 0.6 : pm25 <= 55 ? 1.0 : pm25 <= 150 ? 1.5 : 2.0;
      
      this.init();
    }

    private init() {
      // Get WebGL context
      this.gl = this.canvas.getContext('webgl', {
        alpha: false,
        antialias: false,
        powerPreference: 'low-power' // Save battery on mobile
      });

      if (!this.gl) {
        console.warn('WebGL not supported, falling back to CSS');
        this.fallback();
        return;
      }

      // Create shaders
      const vertexShader = this.createShader(this.gl.VERTEX_SHADER, this.vertexShaderSource);
      const fragmentShader = this.createShader(this.gl.FRAGMENT_SHADER, this.fragmentShaderSource);

      if (!vertexShader || !fragmentShader) {
        this.fallback();
        return;
      }

      // Create program
      this.program = this.createProgram(vertexShader, fragmentShader);
      if (!this.program) {
        this.fallback();
        return;
      }

      // Get uniform locations
      this.uniforms.uTime = this.gl.getUniformLocation(this.program, 'uTime');
      this.uniforms.uResolution = this.gl.getUniformLocation(this.program, 'uResolution');
      this.uniforms.uPrimaryColor = this.gl.getUniformLocation(this.program, 'uPrimaryColor');
      this.uniforms.uSecondaryColor = this.gl.getUniformLocation(this.program, 'uSecondaryColor');
      this.uniforms.uSpeed = this.gl.getUniformLocation(this.program, 'uSpeed');

      // Setup geometry (fullscreen quad)
      this.setupGeometry();

      // Start rendering
      this.resize();
      this.animate();
      
      window.addEventListener('resize', () => this.resize());
    }

    private createShader(type: number, source: string): WebGLShader | null {
      if (!this.gl) return null;
      
      const shader = this.gl.createShader(type);
      if (!shader) return null;

      this.gl.shaderSource(shader, source);
      this.gl.compileShader(shader);

      if (!this.gl.getShaderParameter(shader, this.gl.COMPILE_STATUS)) {
        console.error('Shader compile error:', this.gl.getShaderInfoLog(shader));
        this.gl.deleteShader(shader);
        return null;
      }

      return shader;
    }

    private createProgram(vertexShader: WebGLShader, fragmentShader: WebGLShader): WebGLProgram | null {
      if (!this.gl) return null;
      
      const program = this.gl.createProgram();
      if (!program) return null;

      this.gl.attachShader(program, vertexShader);
      this.gl.attachShader(program, fragmentShader);
      this.gl.linkProgram(program);

      if (!this.gl.getProgramParameter(program, this.gl.LINK_STATUS)) {
        console.error('Program link error:', this.gl.getProgramInfoLog(program));
        this.gl.deleteProgram(program);
        return null;
      }

      return program;
    }

    private setupGeometry() {
      if (!this.gl || !this.program) return;

      // Fullscreen quad (triangle strip)
      const positions = new Float32Array([
        -1, -1,
         1, -1,
        -1,  1,
         1,  1
      ]);

      const buffer = this.gl.createBuffer();
      this.gl.bindBuffer(this.gl.ARRAY_BUFFER, buffer);
      this.gl.bufferData(this.gl.ARRAY_BUFFER, positions, this.gl.STATIC_DRAW);

      const aPosition = this.gl.getAttribLocation(this.program, 'aPosition');
      this.gl.enableVertexAttribArray(aPosition);
      this.gl.vertexAttribPointer(aPosition, 2, this.gl.FLOAT, false, 0, 0);
    }

    private resize() {
      // Use lower resolution on mobile for performance
      const dpr = Math.min(window.devicePixelRatio, 1.5);
      const displayWidth = Math.floor(window.innerWidth * dpr);
      const displayHeight = Math.floor(window.innerHeight * dpr);
      
      this.canvas.width = displayWidth;
      this.canvas.height = displayHeight;
      
      if (this.gl) {
        this.gl.viewport(0, 0, displayWidth, displayHeight);
      }
    }

    private animate() {
      if (!this.gl || !this.program) return;

      const elapsed = (Date.now() - this.startTime) / 1000;

      this.gl.useProgram(this.program);

      // Update uniforms
      this.gl.uniform1f(this.uniforms.uTime, elapsed);
      this.gl.uniform2f(this.uniforms.uResolution, this.canvas.width, this.canvas.height);
      this.gl.uniform3fv(this.uniforms.uPrimaryColor, this.primaryColor);
      this.gl.uniform3fv(this.uniforms.uSecondaryColor, this.secondaryColor);
      this.gl.uniform1f(this.uniforms.uSpeed, this.speed);

      // Draw
      this.gl.drawArrays(this.gl.TRIANGLE_STRIP, 0, 4);

      this.animationId = requestAnimationFrame(() => this.animate());
    }

    private fallback() {
      // CSS gradient fallback
      this.canvas.style.background = `
        radial-gradient(ellipse at 30% 20%, 
          rgba(${this.primaryColor.join(',')}, 0.4) 0%, 
          transparent 50%),
        radial-gradient(ellipse at 70% 80%, 
          rgba(${this.secondaryColor.join(',')}, 0.3) 0%, 
          transparent 50%),
        linear-gradient(135deg, #1a1a2e 0%, #16213e 100%)
      `;
    }

    destroy() {
      cancelAnimationFrame(this.animationId);
      if (this.gl) {
        this.gl.deleteProgram(this.program);
        this.gl = null;
      }
    }
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  function init() {
    const canvas = document.getElementById('liquid-canvas') as HTMLCanvasElement;
    if (canvas) {
      new LiquidBackground(canvas);
    }
  }
</script>