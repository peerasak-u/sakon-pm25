---
interface Props {
  logDatetime: string;
}

const { logDatetime } = Astro.props;

// Format datetime
function formatTime(datetime: string): string {
  try {
    const date = new Date(datetime);
    const bangkokTime = new Date(date.toLocaleString("en-US", { timeZone: "Asia/Bangkok" }));
    
    const hours = bangkokTime.getHours().toString().padStart(2, '0');
    const minutes = bangkokTime.getMinutes().toString().padStart(2, '0');
    const day = bangkokTime.getDate().toString().padStart(2, '0');
    const month = (bangkokTime.getMonth() + 1).toString().padStart(2, '0');
    const year = bangkokTime.getFullYear();
    
    return `${hours}:${minutes} · ${day}/${month}/${year}`;
  } catch {
    return datetime;
  }
}

const formattedTime = formatTime(logDatetime);
const isoTime = new Date(logDatetime).toISOString();
---

<footer class="last-updated">
  <time datetime={isoTime} class="timestamp">
    <span class="label">Updated</span>
    <span class="time">{formattedTime}</span>
  </time>
  <div class="data-source">
    <span class="source-label">Data from CCDC Station</span>
  </div>
</footer>

<style>
  .last-updated {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 0;
    opacity: 0.6;
    transition: opacity 0.3s ease;
  }

  .last-updated:hover {
    opacity: 1;
  }

  .timestamp {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
  }

  .label {
    font-size: 0.625rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .time {
    font-size: 0.75rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.02em;
  }

  .data-source {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .source-label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.05em;
  }

  /* Responsive */
  @media (min-width: 768px) {
    .last-updated {
      gap: 0.625rem;
    }

    .label {
      font-size: 0.6875rem;
    }

    .time {
      font-size: 0.8125rem;
    }

    .source-label {
      font-size: 0.6875rem;
    }
  }
</style>