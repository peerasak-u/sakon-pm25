---
interface Props {
  usCaption: string;
  usCaptionEn: string;
}

const { usCaption, usCaptionEn } = Astro.props;

// Parse AQI level from caption to determine severity
function getAQILevel(caption: string): 'low' | 'moderate' | 'high' | 'severe' {
  const lower = caption.toLowerCase();
  if (lower.includes('ดี') || lower.includes('good')) return 'low';
  if (lower.includes('ปานกลาง') || lower.includes('moderate')) return 'moderate';
  if (lower.includes('เฝ้าระวัง') || lower.includes('sensitive')) return 'moderate';
  if (lower.includes('ไม่ดี') || lower.includes('unhealthy')) return 'high';
  if (lower.includes('อันตราย') || lower.includes('hazardous')) return 'severe';
  return 'moderate';
}

const level = getAQILevel(usCaption);

const levelConfig = {
  low: { glowIntensity: 0.3, borderOpacity: 0.2 },
  moderate: { glowIntensity: 0.4, borderOpacity: 0.3 },
  high: { glowIntensity: 0.5, borderOpacity: 0.4 },
  severe: { glowIntensity: 0.6, borderOpacity: 0.5 }
};

const config = levelConfig[level];

// Truncate captions for cleaner display
function truncateCaption(caption: string, maxLength: number = 200): string {
  if (caption.length <= maxLength) return caption;
  return caption.substring(0, maxLength).trim() + '...';
}

const shortCaptionTh = truncateCaption(usCaption, 180);
const shortCaptionEn = truncateCaption(usCaptionEn, 160);
---

<div class="glass-card" style={`--glow-intensity: ${config.glowIntensity}; --border-opacity: ${config.borderOpacity}`}>
  <div class="glass-border"></div>
  <div class="glass-content">
    <p class="caption-th">{shortCaptionTh}</p>
    <p class="caption-en">{shortCaptionEn}</p>
  </div>
  <div class="glass-shine" aria-hidden="true"></div>
</div>

<style>
  .glass-card {
    position: relative;
    width: 100%;
    max-width: 480px;
    margin: 0 auto;
    padding: 1.5rem;
    border-radius: 24px;
    overflow: hidden;
    
    /* Frosted glass background */
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    
    /* Glass border */
    border: 1px solid rgba(255, 255, 255, var(--border-opacity, 0.3));
    
    /* Subtle glow based on AQI */
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.05) inset,
      0 8px 32px rgba(0, 0, 0, 0.3),
      0 0 60px rgba(var(--theme-color), calc(var(--glow-intensity, 0.4) * 0.3));
    
    /* Smooth transitions */
    transition: all 0.3s ease;
  }

  .glass-border {
    position: absolute;
    inset: 0;
    border-radius: 24px;
    pointer-events: none;
    
    /* Gradient border effect */
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.2) 0%,
      rgba(255, 255, 255, 0.05) 50%,
      rgba(255, 255, 255, 0.1) 100%
    );
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask-composite: exclude;
    -webkit-mask-composite: xor;
    padding: 1px;
  }

  .glass-content {
    position: relative;
    z-index: 2;
    text-align: center;
  }

  .caption-th {
    font-family: var(--font-thai);
    font-size: 1.125rem;
    font-weight: 400;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.9);
    margin: 0 0 0.75rem 0;
  }

  .caption-en {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 400;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  /* Glass shine reflection */
  .glass-shine {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 40%;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.15) 0%,
      rgba(255, 255, 255, 0.05) 40%,
      transparent 100%
    );
    border-radius: 24px 24px 0 0;
    pointer-events: none;
    z-index: 1;
  }

  /* Hover effect */
  .glass-card:hover {
    background: rgba(255, 255, 255, 0.12);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.1) inset,
      0 12px 40px rgba(0, 0, 0, 0.4),
      0 0 80px rgba(var(--theme-color), calc(var(--glow-intensity, 0.4) * 0.4));
    transform: translateY(-2px);
  }

  /* Responsive */
  @media (min-width: 768px) {
    .glass-card {
      padding: 2rem;
      border-radius: 28px;
    }

    .glass-border {
      border-radius: 28px;
    }

    .glass-shine {
      border-radius: 28px 28px 0 0;
    }

    .caption-th {
      font-size: 1.25rem;
    }

    .caption-en {
      font-size: 1rem;
    }
  }

  /* Safari fix for backdrop-filter */
  @supports not (backdrop-filter: blur(20px)) {
    .glass-card {
      background: rgba(40, 40, 50, 0.85);
    }
  }

  /* Reduced transparency for accessibility */
  @media (prefers-reduced-transparency: reduce) {
    .glass-card {
      background: rgba(30, 30, 35, 0.95);
      backdrop-filter: none;
    }
  }
</style>