---
interface Props {
  usCaption: string;     // Thai health advice
  usCaptionEn: string;   // English health advice
}

const { usCaption, usCaptionEn } = Astro.props;
---

<div class="health-card">
  <div class="health-icon">
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" stroke="currentColor" stroke-width="1.5" fill="none"/>
      <path d="M12 8v8M8 12h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </div>
  
  <div class="health-content">
    <p class="health-thai">{usCaption}</p>
    <p class="health-en">{usCaptionEn}</p>
  </div>
</div>

<style>
  .health-card {
    background: var(--color-bg-secondary);
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 1.25rem;
    max-width: 500px;
    width: 100%;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    backdrop-filter: blur(10px);
    z-index: 10;
    /* Dynamic subtle glow from theme */
    box-shadow: 
      0 4px 20px rgba(0, 0, 0, 0.3),
      0 0 40px rgba(var(--theme-color), 0.08);
  }

  .health-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    color: rgb(var(--theme-color));
    background: rgba(var(--theme-color), 0.15);
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .health-icon svg {
    width: 22px;
    height: 22px;
  }

  .health-content {
    flex: 1;
    min-width: 0;
  }

  .health-thai {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-text-primary);
    margin: 0;
  }

  .health-en {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0.625rem 0 0 0;
  }

  @media (min-width: 768px) {
    .health-card {
      padding: 1.5rem;
      max-width: 550px;
    }

    .health-icon {
      width: 48px;
      height: 48px;
    }

    .health-icon svg {
      width: 26px;
      height: 26px;
    }

    .health-thai {
      font-size: 1.0625rem;
    }

    .health-en {
      font-size: 0.9375rem;
    }
  }
</style>
