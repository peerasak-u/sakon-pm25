---
import Layout from '../layouts/Layout.astro';
import LiquidBackground from '../components/LiquidBackground.astro';
import GlassCard from '../components/GlassCard.astro';

// Load data
import data from '../data/pm25-history.json';

const latest = data.readings[data.readings.length - 1];
const station = data.station;

const fallback = {
  pm25: 54,
  us_aqi: 147,
  us_title: 'คุณภาพอากาศไม่ดีต่อกลุ่มเสี่ยง',
  us_title_en: 'Unhealthy for Sensitive Groups',
  us_caption: 'ประชาชนที่ไวต่อมลพิษมากกว่าคนทั่วไปควรลดการออกแรงหนัก',
  us_caption_en: 'Members of sensitive groups may experience health effects. The general public is not likely to be affected.',
  us_color: '235, 132, 63',
  datetime: new Date().toISOString()
};

const r = latest || fallback;

// Clean location
const location = (station?.name_en || 'Sraphangthong pond, Somdej Phra Srinakarin Park, Sakon Nakhon Province')
  .replace('Somdej Phra Srinakarin Park, ', '')
  .replace(' Province', '');

const aqiLevel = r.us_aqi <= 50 ? 'good' : 
                 r.us_aqi <= 100 ? 'moderate' : 
                 r.us_aqi <= 150 ? 'sensitive' : 
                 r.us_aqi <= 200 ? 'unhealthy' : 
                 r.us_aqi <= 300 ? 'very-unhealthy' : 'hazardous';

const assets = {
  good: { favicon: '/favicon/favicon-good.svg', ogImage: '/og/og-aqi-good.png' },
  moderate: { favicon: '/favicon/favicon-moderate.svg', ogImage: '/og/og-aqi-moderate.png' },
  sensitive: { favicon: '/favicon/favicon-sensitive.svg', ogImage: '/og/og-aqi-sensitive.png' },
  unhealthy: { favicon: '/favicon/favicon-unhealthy.svg', ogImage: '/og/og-aqi-unhealthy.png' },
  'very-unhealthy': { favicon: '/favicon/favicon-very-unhealthy.svg', ogImage: '/og/og-aqi-very-unhealthy.png' },
  hazardous: { favicon: '/favicon/favicon-hazardous.svg', ogImage: '/og/og-aqi-hazardous.png' }
}[aqiLevel];
---

<Layout 
  title={`${r.us_title_en} — PM2.5 Sakon Nakhon`}
  description={`${location} — PM2.5 is ${r.pm25} μg/m³ (AQI ${r.us_aqi})`}
  ogImage={assets.ogImage}
  favicon={assets.favicon}
  aqiLevel={aqiLevel}
>
  <div class="app">
    <!-- Animated liquid background -->
    <LiquidBackground pm25={r.pm25} usColor={r.us_color} />
    
    <!-- Centered glass card with all content -->
    <main class="centered">
      <GlassCard 
        location={location}
        pm25={r.pm25}
        aqi={r.us_aqi}
        usTitle={r.us_title}
        usTitleEn={r.us_title_en}
        usCaption={r.us_caption}
        usCaptionEn={r.us_caption_en}
        datetime={r.datetime}
      />
    </main>
  </div>
</Layout>

<style>
  .app {
    min-height: 100dvh;
    position: relative;
    /* Light gray base */
    background: linear-gradient(
      180deg,
      #a0a4ac 0%,
      #b0b4bc 50%,
      #c0c4cc 100%
    );
  }

  .centered {
    position: relative;
    z-index: 2;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  @media (min-width: 768px) {
    .centered {
      padding: 2rem;
    }
  }
</style>