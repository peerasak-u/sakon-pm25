# CCDC API Configuration
# Get your API key from: https://open-api.cmuccdc.org/

# Base API URL (without apikey parameter)
# Use one of these:
# CCDC_API_URL=https://open-api.cmuccdc.org/api/dustboy/stations  # Returns all stations
CCDC_API_URL=https://open-api.cmuccdc.org/api/dustboy/station     # Returns your configured station

# Your CCDC API Key
CCDC_API_KEY=your_api_key_here

# Target Station ID
STATION_ID=4473
